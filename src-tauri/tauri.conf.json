{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vocrify",
  "version": "0.1.0",
  "identifier": "com.vocrify",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "bun run prepare:tauri-resources && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vocrify",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 800,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/**/*"]
  }
}
