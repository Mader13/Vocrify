{
  "name": "transcribe-video",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ai": "cd ai-engine && venv/Scripts/python.exe main.py --server",
    "prepare:tauri-resources": "bun run scripts/prepare-tauri-resources.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "bun run prepare:tauri-resources && tauri dev",
    "tauri:build": "bun run prepare:tauri-resources && tauri build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\""
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-store": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.33.0",
    "lucide-react": "^0.563.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-window": "^2.2.6",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "wavesurfer.js": "^7.12.1",
    "zod": "^3.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.2.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/react-window": "^2.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "claude-flow": "^3.1.0-alpha.14",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "terser": "^5.46.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.0.4",
    "vitest": "^2.1.8"
  },
  "description": "A cross-platform desktop application for video transcription with speaker diarization.",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "overrides": {
    "tar": "^7.0.0",
    "node-gyp": "^11.0.0",
    "sqlite3": "^5.1.7",
    "cacache": "^19.0.0",
    "make-fetch-happen": "^14.0.0",
    "@mapbox/node-pre-gyp": "^2.0.0"
  }
}
